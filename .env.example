# Romanian TTS API + MCP server configuration.
# Copy to .env and adjust. Used by docker-compose (romanian-tts service).

# Host port the API/MCP is published on (container always listens on 8000).
ROMANIAN_PORT=8001

# Default engine when a request does not specify one: auto | xtts | pocket
# auto = XTTS (native) with pocket-tts (fast Italian base) fallback.
ROMANIAN_DEFAULT_ENGINE=auto

# Max characters accepted per request.
ROMANIAN_MAX_CHARS=1000

# Content cache: identical (text, engine, voice, reference clip) requests are served from
# disk instead of being regenerated. Set to 0 to disable. The cache index lives in the
# output directory (cache_index.json) and persists across restarts.
ROMANIAN_CACHE=1

# Preload engines at startup (1) or lazily on first request (0).
# Primary = XTTS (heavy download + load, ~minutes on first run).
ROMANIAN_PRELOAD_PRIMARY=1
ROMANIAN_PRELOAD_SECONDARY=1

# Base URL returned in MCP tool results for the /outputs download links.
# Set this to how Jarvis reaches the container (e.g. http://romanian-tts:8000 on a shared
# docker network, or a public URL behind a reverse proxy).
ROMANIAN_PUBLIC_BASE_URL=http://localhost:8001

# Optional: override the XTTS model repo or default speaker.
# ROMANIAN_MODEL_REPO=
# ROMANIAN_XTTS_SPEAKER=
# ROMANIAN_DEFAULT_SPEAKER_WAV=
